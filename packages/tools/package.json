{
  "name": "@organic/tools",
  "version": "0.1.0",
  "type": "module",
  "description": "Tool Service module for Organic Interface - provides tool registration, discovery, and execution",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "cd ../.. && pnpm exec vitest run packages/tools/src",
    "lint": "cd ../.. && pnpm exec eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@organic/kernel": "workspace:*",
    "@organic/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "organic",
    "tools",
    "agent",
    "plugin"
  ],
  "author": "",
  "license": "MIT"
}
